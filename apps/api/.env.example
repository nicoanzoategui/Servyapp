PORT=3000
# URL del sitio principal (links en emails, redirects, etc.)
FRONTEND_URL=http://localhost:3001
# URL pública de esta API (webhooks Mercado Pago, etc.)
API_PUBLIC_URL=http://localhost:3000
# Una URL, varias separadas por coma, o * (solo dev; en prod listá orígenes explícitos)
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003

# Generá secretos largos y distintos (p. ej. openssl rand -base64 48). No subir a git.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d

# WhatsApp Cloud API
WA_TOKEN=
WA_PHONE_ID=
WA_APP_SECRET=
WA_VERIFY_TOKEN=
# Desarrollo local sin validar firma Meta (no usar en producción)
WA_SKIP_SIGNATURE=true

# Twilio WhatsApp (Sandbox o número aprobado). TWILIO_PHONE_NUMBER: E.164 o whatsapp:+E164
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Local: redis://localhost:6379 | Railway: URL pública del servicio Redis (mismo host que el proxy TCP)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Mercado Pago (dejar valores dummy hasta integrar; PAYMENTS_ENABLED=false)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PAYMENTS_ENABLED=false

# Resend (emails portal pro) + URL del portal para links en mails
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FRONTEND_PRO_URL=http://localhost:3003

# Google Gemini (clasificación de pedidos en WhatsApp)
GEMINI_API_KEY=
