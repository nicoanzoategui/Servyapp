PORT=3000
# URL del sitio principal (links en emails, redirects, etc.)
FRONTEND_URL=http://localhost:3001
# URL pública de esta API (webhooks Mercado Pago, etc.)
API_PUBLIC_URL=http://localhost:3000
# Una URL, varias separadas por coma, o * (solo dev; en prod listá orígenes explícitos)
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003

# Generá secretos largos y distintos (p. ej. openssl rand -base64 48). No subir a git.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d

# WhatsApp Cloud API
WA_TOKEN=
WA_PHONE_ID=
WA_APP_SECRET=
WA_VERIFY_TOKEN=
# Desarrollo local sin validar firma Meta (no usar en producción)
WA_SKIP_SIGNATURE=true

# Twilio WhatsApp (Sandbox o número aprobado). TWILIO_PHONE_NUMBER: E.164 o whatsapp:+E164
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# true = loguea JSON del body Twilio en Railway (solo mientras depurás el webhook)
TWILIO_WEBHOOK_DEBUG=false

# Local: redis://localhost:6379 | Railway: URL pública del servicio Redis (mismo host que el proxy TCP)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Mercado Pago (dejar valores dummy hasta integrar; PAYMENTS_ENABLED=false)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PAYMENTS_ENABLED=false
# Solo true con cuidado: reembolso automático en MP ante payment_anomaly (fraude).
MP_AUTO_REFUND_FRAUD=false

# Resend (emails portal pro) + URL del portal para links en mails
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FRONTEND_PRO_URL=http://localhost:3003

# Google Gemini (bot + agentes). Opcional: alias del spec (si está, tiene prioridad).
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=

# Agentes: MercadoLibre público, Apify/Meta (opcional)
MERCADOLIBRE_API_URL=https://api.mercadolibre.com
APIFY_API_TOKEN=
META_AD_ACCOUNT_ID=
META_SYSTEM_USER_TOKEN=
META_PAGE_ID=

# Prisma seed (packages/db): usuario Nicolás + plomero en Pilar/1629 para pruebas de matching.
# Solo dígitos (sin +). Al correr db:seed, exportá o poné en el mismo .env que DATABASE_URL.
# SEED_NICOLAS_CLIENT_PHONE=5491115000001
# SEED_NICOLAS_PRO_PHONE=5491115000002
